          "source" : "PRECISE Longitudinal Assessment",
          "target" : null
        },
        {
          "id" : "ImplementationGuide.definition.resource.description",
          "context" : "ImplementationGuide.definition.resource.description",
          "source" : "PRECISE is an exam-level longitudinal assessment for prostate MRI follow-up.\nIt summarizes overall change compared to a prior MRI examination, using the PRECISE framework.\n\nPRECISE does not replace PI-RADS (which is lesion-level). Instead, it provides a\npatient/exam-level progression/regression category informed by lesion changes.",
          "target" : null
        },
        {
          "id" : "ImplementationGuide.definition.resource.name",
          "context" : "ImplementationGuide.definition.resource.name",
          "source" : "Prostate Lesion",
          "target" : null
        },
        {
          "id" : "ImplementationGuide.definition.resource.description",
          "context" : "ImplementationGuide.definition.resource.description",
          "source" : "An anatomical prostate lesion identified on MRI and localized using\nthe PI-RADS 39-sector model.\nLesion location is encoded using specific SNOMED CT body structure\nconcepts representing exact prostate sectors (base/mid/apex, zone,\nside and position).",
          "target" : null
        },
        {
          "id" : "ImplementationGuide.definition.resource.name",
          "context" : "ImplementationGuide.definition.resource.name",
          "source" : "Prostate mpMRI Diagnostic Report",
          "target" : null
        },
        {
          "id" : "ImplementationGuide.definition.resource.description",
          "context" : "ImplementationGuide.definition.resource.description",
          "source" : "DiagnosticReport representing a prostate MRI examination (bi-parametric or multi-parametric).\n\nThis resource acts as the clinical and temporal anchor for all imaging-based\nassessments and measurements, including PI-RADS assessment, MRI sequence scores,\nPI-QUAL image quality evaluation, prostate volume and PSAD.\n\nThe report itself contains the overall narrative conclusion, while detailed\nfindings are represented as linked Observation and BodyStructure resources.",
          "target" : null
        },
        {
          "id" : "ImplementationGuide.definition.resource.name",
          "context" : "ImplementationGuide.definition.resource.name",
          "source" : "Prostate mpMRI Sequence Type ValueSet",
          "target" : null
        },
        {
          "id" : "ImplementationGuide.definition.resource.description",
          "context" : "ImplementationGuide.definition.resource.description",
          "source" : "Sequence/image types used in prostate mpMRI scoring (DICOM terminology).",
          "target" : null
        },
        {
          "id" : "ImplementationGuide.definition.resource.name",
          "context" : "ImplementationGuide.definition.resource.name",
          "source" : "Prostate MRI Sequence Score Observation",
          "target" : null
        },
        {
          "id" : "ImplementationGuide.definition.resource.description",
          "context" : "ImplementationGuide.definition.resource.description",
          "source" : "Observation representing a numeric (1–5) assessment score for a specific prostate\nMRI sequence (T2-weighted, DWI, ADC or DCE), evaluated for a defined prostate lesion.\nThese sequence-level scores represent the individual imaging components used\nto derive the overall PI-RADS assessment, but do not themselves constitute a\nfinal diagnostic conclusion.\nAnatomical localization is provided via the referenced LTProstateLesion.",
          "target" : null
        },
        {
          "id" : "ImplementationGuide.definition.resource.name",
          "context" : "ImplementationGuide.definition.resource.name",
          "source" : "Prostate MRI Type ValueSet",
          "target" : null
        },
        {
          "id" : "ImplementationGuide.definition.resource.description",
