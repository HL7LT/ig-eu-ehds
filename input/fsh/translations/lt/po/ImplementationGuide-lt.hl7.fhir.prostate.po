#: ImplementationGuide.definition.resource.name
msgid "Prostate MRI Type ValueSet"
msgstr ""

# ImplementationGuide.definition.resource.description
#: ImplementationGuide.definition.resource.description
msgid "Type of prostate MRI examination: bi-parametric or multi-parametric."
msgstr ""

