{
  "resourceType": "StructureDefinition",
  "id": "lt-prostate-mpmri-report",
  "url": "https://hl7.lt/fhir/prostate/StructureDefinition/lt-prostate-mpmri-report",
  "name": "LTProstateMpMRIReport",
  "title": "Prostate mpMRI Diagnostic Report",
  "status": "draft",
  "description": "DiagnosticReport representing a prostate MRI examination (bi-parametric or multi-parametric).\n\nThis resource acts as the clinical and temporal anchor for all imaging-based\nassessments and measurements, including PI-RADS assessment, MRI sequence scores,\nPI-QUAL image quality evaluation, prostate volume and PSAD.\n\nThe report itself contains the overall narrative conclusion, while detailed\nfindings are represented as linked Observation and BodyStructure resources.",
  "fhirVersion": "5.0.0",
  "kind": "resource",
  "abstract": false,
  "type": "DiagnosticReport",
  "baseDefinition": "http://hl7.eu/fhir/imaging-r5/StructureDefinition/ImDiagnosticReport",
  "derivation": "constraint",
  "differential": {
    "element": [
      {
        "id": "DiagnosticReport.code.coding",
        "path": "DiagnosticReport.code.coding",
        "max": "1"
      },
      {
        "id": "DiagnosticReport.code.coding.system",
        "path": "DiagnosticReport.code.coding.system",
        "patternUri": "http://snomed.info/sct"
      },
      {
        "id": "DiagnosticReport.code.coding.code",
        "path": "DiagnosticReport.code.coding.code",
        "min": 1,
        "binding": {
          "strength": "required",
          "valueSet": "https://hl7.lt/fhir/prostate/ValueSet/lt-prostate-mri-type-vs"
        }
      },
      {
        "id": "DiagnosticReport.subject",
        "path": "DiagnosticReport.subject",
        "min": 1
      },
      {
        "id": "DiagnosticReport.encounter",
        "path": "DiagnosticReport.encounter",
        "type": [
          {
            "code": "Reference",
            "targetProfile": [
              "https://hl7.lt/fhir/base/StructureDefinition/lt-encounter"
            ]
          }
        ]
      },
      {
        "id": "DiagnosticReport.effective[x]",
        "path": "DiagnosticReport.effective[x]",
        "min": 1,
        "type": [
          {
            "code": "dateTime"
          }
        ]
      },
      {
        "id": "DiagnosticReport.result",
        "path": "DiagnosticReport.result",
        "short": "Imaging-based observations including PI-RADS, sequence scores, PI-QUAL and PRECISE assessment"
      },
      {
        "id": "DiagnosticReport.conclusion",
        "path": "DiagnosticReport.conclusion",
        "min": 1
      }
    ]
  }
}
