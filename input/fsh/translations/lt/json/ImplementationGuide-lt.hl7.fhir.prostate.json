          "source" : "PI-QUAL Score",
          "target" : null
        },
        {
          "id" : "ImplementationGuide.definition.resource.description",
          "context" : "ImplementationGuide.definition.resource.description",
          "source" : "PI-QUAL is a quality assurance score for prostate MRI examinations.\nIt reflects whether the technical image quality of a specific MRI exam\nis sufficient to allow reliable interpretation and PI-RADS assessment.\n\nThis score applies to the entire MRI examination (not to individual lesions).\n\nLow PI-QUAL scores indicate that PI-RADS results should be interpreted\nwith caution or may not be reliable.",
          "target" : null
        },
        {
          "id" : "ImplementationGuide.definition.resource.name",
          "context" : "ImplementationGuide.definition.resource.name",
          "source" : "PI-QUAL ValueSet",
          "target" : null
        },
        {
          "id" : "ImplementationGuide.definition.resource.name",
          "context" : "ImplementationGuide.definition.resource.name",
          "source" : "PI-RADS Assessment",
          "target" : null
        },
        {
          "id" : "ImplementationGuide.definition.resource.description",
          "context" : "ImplementationGuide.definition.resource.description",
          "source" : "PI-RADS assessment (score 1–5) assigned to a specific prostate lesion\nbased on mpMRI findings.\nThe anatomical location is represented using detailed PI-RADS\nsector-based prostate body structures (39-sector map).",
          "target" : null
        },
        {
          "id" : "ImplementationGuide.definition.resource.name",
          "context" : "ImplementationGuide.definition.resource.name",
          "source" : "PI-RADS Prostate Sector (39-sector map)",
          "target" : null
        },
        {
          "id" : "ImplementationGuide.definition.resource.description",
          "context" : "ImplementationGuide.definition.resource.description",
          "source" : "PI-RADS prostate sector locations based on the 39-sector PI-RADS map.\nIncludes detailed SNOMED CT body structure codes for base/mid/apex,\nzone, side, and anterior/posterior subdivisions.",
          "target" : null
        },
        {
          "id" : "ImplementationGuide.definition.resource.name",
